`timescale 1 us / 1 ns 

module ALU_16bit_tb();
  
  reg [15:0] A_tb;
  reg [15:0] B_tb;
  reg [3:0] ALU_FUN_tb;
  reg CLK_tb;
  wire [15:0] ALU_OUT_tb;
  wire Arith_Flag_tb;
  wire Logic_Flag_tb;
  wire CMP_Flag_tb;
  wire Shift_Flag_tb;
  
  initial
    begin
      $dumpfile("ALU_16bit.vcd");
      $dumpvars;
      // Initial Values
      A_tb = 16'd8;
      B_tb = 16'd3;
      ALU_FUN_tb = 4'b0000;
      CLK_tb = 1'b0;
      
      #10 
      ALU_FUN_tb = 4'b0001;
      if (ALU_OUT_tb == 16'd11 && Arith_Flag_tb == 1'b1)
        $display("Addition operation test passed");
      else
        $display("Addition operation test failed");

      #10 
      ALU_FUN_tb = 4'b0010;
      if (ALU_OUT_tb == 16'd5 && Arith_Flag_tb == 1'b1)
        $display("Subtraction operation test passed");
      else
        $display("Subtraction operation test failed");
        
      #10 
      ALU_FUN_tb = 4'b0011;
      if (ALU_OUT_tb == 16'd24 && Arith_Flag_tb == 1'b1)
        $display("Multiplication operation test passed");
      else
        $display("Multiplication operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b0100;
      if (ALU_OUT_tb == 16'd2 && Arith_Flag_tb == 1'b1)
        $display("Division operation test passed");
      else
        $display("Division operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b0101;
      if (ALU_OUT_tb == 16'd0 && Logic_Flag_tb == 1'b1)
        $display("Logic AND operation test passed");
      else
        $display("Logic AND operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b0110;
      if (ALU_OUT_tb == 16'd11 && Logic_Flag_tb == 1'b1)
        $display("Logic OR operation test passed");
      else
        $display("Logic OR operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b0111;
      if (ALU_OUT_tb == 16'hFFFF && Logic_Flag_tb == 1'b1)
        $display("Logic NAND operation test passed");
      else
        $display("Logic NAND operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1000;
      if (ALU_OUT_tb == 16'hFFF4 && Logic_Flag_tb == 1'b1)
        $display("Logic NOR operation test passed");
      else
        $display("Logic NOR operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1001;
      if (ALU_OUT_tb == 16'd11 && Logic_Flag_tb == 1'b1)
        $display("Logic XOR operation test passed");
      else
        $display("Logic XOR operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1010;
      if (ALU_OUT_tb == 16'hFFF4 && Logic_Flag_tb == 1'b1)
        $display("Logic XNOR operation test passed");
      else
        $display("Logic XNOR operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1011;
      if (ALU_OUT_tb == 16'd0 && CMP_Flag_tb == 1'b1)
        $display("Compare operation test passed");
      else
        $display("Compare operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1100;
      if (ALU_OUT_tb == 16'd2 && CMP_Flag_tb == 1'b1)
        $display("Greater than operation test passed");
      else
        $display("Greater than operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1101;
      if (ALU_OUT_tb == 16'd0 && CMP_Flag_tb == 1'b1)
        $display("Smaller than operation test passed");
      else
        $display("Smaller than operation test failed");
      
      #10
      ALU_FUN_tb = 4'b1110;
      if (ALU_OUT_tb == 16'd4 && Shift_Flag_tb == 1'b1)
        $display("Shift right operation test passed");
      else
        $display("Shift right operation test failed");
      
      #10 
      ALU_FUN_tb = 4'b1111;
      if (ALU_OUT_tb == 16'd16 && Shift_Flag_tb == 1'b1)
        $display("Shift left operation test passed");
      else
        $display("Shift left operation test failed");
      
    end
    
  // 10 us clock period
  always #5 CLK_tb = ~CLK_tb;
  
  ALU_16bit DUT (
  .A (A_tb),
  .B (B_tb),
  .ALU_FUN (ALU_FUN_tb),
  .CLK (CLK_tb),
  .ALU_OUT (ALU_OUT_tb),
  .Arith_Flag (Arith_Flag_tb),
  .Logic_Flag (Logic_Flag_tb),
  .CMP_Flag (CMP_Flag_tb),
  .Shift_Flag (Shift_Flag_tb)
  );

endmodule